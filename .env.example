# ─── Banco de dados ──────────────────────────────────────────────────────────
POSTGRES_USER=crud_user
POSTGRES_PASSWORD=crud_password
POSTGRES_DB=crud_tasks

# URL completa usada pelo SQLAlchemy (deve referenciar o serviço "db" do docker-compose)
DATABASE_URL=postgresql://crud_user:crud_password@db:5432/crud_tasks

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere um valor seguro com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_secret
ALGORITHM=HS256
