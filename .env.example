# Variáveis usadas pelo container PostgreSQL para criar o banco automaticamente
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=db_gestao_tarefa

# URL usada pelo SQLAlchemy dentro do Docker (host = nome do serviço 'db')
DATABASE_URL=postgresql://your_user:your_password@db:5432/db_gestao_tarefa

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere um valor seguro: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_secret
ALGORITHM=HS256